# Copy to .env and fill in real values. Never commit .env itself.

# --- REST API ---
# Comma-separated list of accepted API keys (X-API-Key header). Required to start the REST API.
KAST_NLM_API_KEYS=
KAST_NLM_API_HOST=127.0.0.1
KAST_NLM_API_PORT=8008

# --- Credential encryption (optional) ---
# 64 hex chars (256-bit key). If unset, a key is generated and persisted to
# ~/.notebooklm-mcp-cli/encryption.key on first use.
KAST_NLM_ENCRYPTION_KEY=

# --- MCP server ---
# minimal | standard | full (default: full, i.e. every tool visible)
KAST_NLM_PROFILE=

# --- AI-generated content marker ---
# Set to false/0/no to disable the inline [AI-GENERATED ...] text prefix.
# The _provenance field on chat responses is always present regardless.
KAST_NLM_AI_MARKER=
KAST_NLM_AI_MARKER_PREFIX=
