# Copiá este archivo a .env y completá los valores reales. Nunca commitees .env.

# --- API REST ---
# Lista de API keys aceptadas, separadas por coma (header X-API-Key). Requerida para arrancar la API REST.
CAST_NLM_API_KEYS=
CAST_NLM_API_HOST=127.0.0.1
CAST_NLM_API_PORT=8008

# --- Cifrado de credenciales (opcional) ---
# 64 caracteres hex (clave de 256 bits). Si no se setea, se genera una clave
# automáticamente y se guarda en ~/.notebooklm-mcp-cli/encryption.key la primera vez.
CAST_NLM_ENCRYPTION_KEY=

# --- Servidor MCP ---
# minimal | standard | full (default: full, o sea todas las herramientas visibles)
CAST_NLM_PROFILE=

# --- Marcador de contenido generado por IA ---
# Poner en false/0/no para desactivar el prefijo de texto inline [AI-GENERATED ...].
# El campo _provenance en las respuestas de chat siempre está presente, sin importar esto.
CAST_NLM_AI_MARKER=
CAST_NLM_AI_MARKER_PREFIX=
